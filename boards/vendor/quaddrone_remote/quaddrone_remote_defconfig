# Enable basic Zephyr features
CONFIG_ZEPHYR=y
CONFIG_SOC_STM32F103C8=y
CONFIG_BOARD_VENDOR_QUADDRONE_REMOTE=y

# Enable console
CONFIG_UART_CONSOLE=y
CONFIG_UART_LINE_CTRL=y

# Enable GPIO
CONFIG_GPIO=y

# Enable LED support
CONFIG_LED=y
CONFIG_LED_GPIO=y

# Enable clock configuration for 72MHz
CONFIG_CLOCK_CONTROL=y
CONFIG_CLOCK_CONTROL_STM32=y
CONFIG_CLOCK_CONTROL_STM32_HSE=y

# Enable ADC
CONFIG_ADC=y
CONFIG_ADC_1=y
CONFIG_ADC_NRFX_ADC=y
CONFIG_ADC_DT=y

# Enable I2C for OLED
CONFIG_I2C=y
CONFIG_I2C_1=y
CONFIG_I2C_NRFX=y
CONFIG_I2C_DT=y

# Enable SPI for NRF24L01
CONFIG_SPI=y
CONFIG_SPI_2=y
CONFIG_SPI_NRFX_SPI=y
CONFIG_SPI_DT=y

# Enable required subsystems
CONFIG_FLASH_MAP=y
CONFIG_DEVICE_POWER_MANAGEMENT=y
CONFIG_POWER=y
CONFIG_PM_DEVICE=y

# Build optimization
CONFIG_CXX=y
CONFIG_HEAP_MEM_POOL_SIZE=10240
CONFIG_STACK_SIZE=2048
CONFIG_MAIN_STACK_SIZE=2048

# Debug options (comment out for production)
# CONFIG_DEBUG=y
# CONFIG_DEBUG_ASSERT=y