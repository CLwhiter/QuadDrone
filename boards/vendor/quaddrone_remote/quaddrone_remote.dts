/dts-v1/;
#include <dt-bindings/zephyr/led.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/pinctrl/stm32-pinctrl.h>
#include "quaddrone_remote-pinctrl.dtsi"

/ {
	model = "QuadDrone ANO Remote Controller";
	compatible = "vendor,quaddrone-remote";

	/* 72MHz clock configuration */
	clocks {
		compatible = "st,stm32f103-rcc";
		status = "okay";

		clocks {
			#address-cells = <1>;
			#size-cells = <1>;
			ranges = <0>;

			clk_hse: hse {
				#clock-cells = <0>;
				compatible = "fixed-clock";
				clock-frequency = <8000000>;
			};

			clk_pll: pll {
				#clock-cells = <0>;
				compatible = "st,stm32f103-pll-clock";
				clocks = <&clk_hse>;
				pll-m = <1>;
				pll-n = <9>;
				pll-p = <2>;
				pll-q = <7>;
				st,clkdiv = <3>;
			};
		};
	};

	chosen {
		zephyr,console = &uart1;
		zephyr,shell-uart = &uart1;
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
	};

	aliases {
		led0 = &led0;
	};

	led0: led {
		gpios = <&gpioc 13 GPIO_ACTIVE_LOW>;
	};

	gpio_keys {
		compatible = "gpio-keys";
		key0: button-key-0 {
			label = "Key 0";
			gpios = <&gpioa 7 GPIO_PULL_UP>;
			linux,code = <0x100>;
		};
		key1: button-key-1 {
			label = "Key 1";
			gpios = <&gpioa 8 GPIO_PULL_UP>;
			linux,code = <0x101>;
		};
		key2: button-key-2 {
			label = "Key 2";
			gpios = <&gpiob 10 GPIO_PULL_UP>;
			linux,code = <0x102>;
		};
	};

	gpio {
		compatible = "st,stm32f103-pinctrl";
		gpio-controller;
		#gpio-cells = <2>;
	};
};

&adc1 {
	status = "okay";
	pinctrl-0 = <&adc1_pa0_pa6>, <&adc1_pb0_pb1>;
	pinctrl-names = "default";
};

&i2c1 {
	status = "okay";
	pinctrl-0 = <&i2c1_pb6_pb7>;
	pinctrl-names = "default";
};

&spi2 {
	status = "okay";
	pinctrl-0 = <&spi2_pb13_14_15>;
	pinctrl-names = "default";
};

&uart1 {
	status = "okay";
	pinctrl-0 = <&uart1_pa9_pa10>;
	pinctrl-names = "default";
};

&pll {
	clocks = <&clk_pll>;
	status = "okay";
};

&gpioc {
	gpio-led {
		gpio-hog;
		gpios = <13 GPIO_ACTIVE_LOW>;
		output-low;
	};
};
